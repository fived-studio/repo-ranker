# =============================================================================
# Repo Ranker — example environment file
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# API server (apps/api-server) — required
# -----------------------------------------------------------------------------

# Port the API server binds to.
PORT=8080

# Shared secret. Clients must send this in the `x-api-key` header.
# Generate a strong random value, e.g. `openssl rand -hex 32`.
API_KEY=replace-me-with-a-long-random-string

# GitHub personal access token. Needs `public_repo` scope; use `repo`
# if you want private repos and traffic stats. Create one at:
#   https://github.com/settings/tokens
GITHUB_TOKEN=ghp_replace_me

# GitHub login (username) whose repositories you want to rank.
GITHUB_USERNAME=your-github-handle

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Set to `production` to disable pretty-printed logs.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Frontend (apps/repo-rank) — optional
# -----------------------------------------------------------------------------

# Dev/preview server port. Defaults to 5173 if unset.
# VITE_PORT=5173

# Base path when the app is served behind a sub-path. Defaults to `/`.
# BASE_PATH=/
